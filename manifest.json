{
  "manifest_version": 3,
  "name": "Google Sidebar",
  "version": "2.0",
  "icons": {
    "128": "icon.png"
  },
  "description": "Google Sidebar giúp bạn có thể tìm kiếm ngay ở thanh bên",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "contextMenus",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Mở Google Sidebar"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}